# --- Django ---
DEBUG=False
SECRET_KEY=***à_remplir***
ALLOWED_HOSTS=***à définir***,localhost,127.0.0.1
TIME_ZONE=America/Toronto

# --- Base de données (PostgreSQL recommandé) ---
# Format dj-database-url / django-environ accepté si tu l’utilises, sinon configure settings.py en conséquence
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/reservation

# --- Emails (mettre un backend console en dev si besoin) ---
DEFAULT_FROM_EMAIL=noreply@univ.ca
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.youruniversity.ca
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# --- Statique (prod) ---
# Example: /srv/plateforme/static
STATIC_ROOT=/ABSOLUTE/PATH/TO/static

# --- Optionnel : cache/redis si activé ---
# CACHES_URL=redis://localhost:6379/1
